#!/bin/bash
# cc-clear — 向指定 Claude Code 会话发送 /clear 命令
# 用法:
#   cc-clear              显示帮助
#   cc-clear -l           列出所有活跃会话
#   cc-clear -t <N>       向第 N 个 Warp tab 发送 /clear
#   cc-clear -a           向所有 Warp tab 逐一发送 /clear
#   cc-clear -p <PID>     向指定 PID 的会话发送 /clear (自动定位 tab)
#   cc-clear -c <CWD>     向匹配工作目录的会话发送 /clear

set -euo pipefail

SESSIONS_DIR="$HOME/.claude/sessions"

# 颜色
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

list_sessions() {
    local i=0
    for f in "$SESSIONS_DIR"/*.json; do
        [ -f "$f" ] || continue
        local pid=$(basename "$f" .json)
        if ! ps -p "$pid" > /dev/null 2>&1; then
            continue
        fi
        local tty=$(ps -o tty= -p "$pid" 2>/dev/null | xargs)
        local cwd=$(python3 -c "import json; print(json.load(open('$f'))['cwd'])" 2>/dev/null || echo "unknown")
        local started=$(python3 -c "
import json, datetime
s = json.load(open('$f'))
print(datetime.datetime.fromtimestamp(s['startedAt']/1000).strftime('%m-%d %H:%M:%S'))
" 2>/dev/null || echo "unknown")
        local session_id=$(python3 -c "import json; print(json.load(open('$f'))['sessionId'])" 2>/dev/null || echo "unknown")
        echo -e "  ${CYAN}[$i]${NC}  PID=${GREEN}$pid${NC}  TTY=$tty  CWD=$cwd  Started=$started"
        echo "       SessionID=$session_id"
        ((i++))
    done
    if [ $i -eq 0 ]; then
        echo -e "  ${YELLOW}没有活跃的 Claude Code 会话${NC}"
        return 1
    fi
    return 0
}

# 通过 TTY 推算 Warp tab 序号
# Warp tab 顺序与 TTY 编号不一定一致，这里用排序后的索引
tty_to_tab_index() {
    local target_tty="$1"
    local ttys=()
    for f in "$SESSIONS_DIR"/*.json; do
        [ -f "$f" ] || continue
        local pid=$(basename "$f" .json)
        if ! ps -p "$pid" > /dev/null 2>&1; then continue; fi
        local tty=$(ps -o tty= -p "$pid" 2>/dev/null | xargs)
        [ -z "$tty" ] && continue
        ttys+=("$tty")
    done
    # 按字符串排序
    IFS=$'\n' sorted=($(sort <<<"${ttys[*]}")); unset IFS
    for i in "${!sorted[@]}"; do
        if [ "${sorted[$i]}" = "$target_tty" ]; then
            echo $((i + 1))
            return
        fi
    done
    echo ""
}

get_pids() {
    local pids=()
    for f in "$SESSIONS_DIR"/*.json; do
        [ -f "$f" ] || continue
        local pid=$(basename "$f" .json)
        if ps -p "$pid" > /dev/null 2>&1; then
            pids+=("$pid")
        fi
    done
    printf '%s\n' "${pids[@]}"
}

# 向指定 Warp tab 序号发送 /clear
send_clear_tab() {
    local tab_num="$1"
    echo -e "  向 Warp tab ${GREEN}$tab_num${NC} 发送 ${YELLOW}/clear${NC} ..."
    osascript -e "
tell application \"Warp\"
    activate
end tell
delay 0.3
tell application \"System Events\"
    keystroke \"$tab_num\" using command down
    delay 0.3
    keystroke \"/\"
    keystroke \"clear\"
    keystroke return
end tell" 2>&1
    if [ $? -eq 0 ]; then
        echo -e "  ${GREEN}发送成功${NC}"
    else
        echo -e "  ${RED}发送失败${NC} — 请检查辅助功能权限"
        return 1
    fi
}

# 通过 PID 自动定位 tab 并发送
send_clear_pid() {
    local pid="$1"
    local tty=$(ps -o tty= -p "$pid" 2>/dev/null | xargs)
    if [ -z "$tty" ]; then
        echo -e "  ${RED}无法获取 PID=$pid 的 TTY${NC}"
        return 1
    fi
    local tab_num=$(tty_to_tab_index "$tty")
    if [ -z "$tab_num" ]; then
        echo -e "  ${RED}无法确定 PID=$pid 的 tab 序号${NC}"
        return 1
    fi
    echo -e "  PID=$pid TTY=$tty -> 推测 tab=${GREEN}$tab_num${NC}"
    send_clear_tab "$tab_num"
}

# 通过 CWD 匹配并发送
send_clear_cwd() {
    local target_cwd="$1"
    for f in "$SESSIONS_DIR"/*.json; do
        [ -f "$f" ] || continue
        local pid=$(basename "$f" .json)
        if ! ps -p "$pid" > /dev/null 2>&1; then continue; fi
        local cwd=$(python3 -c "import json; print(json.load(open('$f'))['cwd'])" 2>/dev/null)
        if [[ "$cwd" == *"$target_cwd"* ]]; then
            send_clear_pid "$pid"
            return
        fi
    done
    echo -e "  ${RED}未找到匹配 CWD=$target_cwd 的会话${NC}"
    return 1
}

# 向所有 tab 逐一发送
send_clear_all() {
    local count=0
    local ttys=()
    for f in "$SESSIONS_DIR"/*.json; do
        [ -f "$f" ] || continue
        local pid=$(basename "$f" .json)
        if ! ps -p "$pid" > /dev/null 2>&1; then continue; fi
        local tty=$(ps -o tty= -p "$pid" 2>/dev/null | xargs)
        [ -z "$tty" ] && continue
        ttys+=("$tty")
        ((count++))
    done
    if [ $count -eq 0 ]; then
        echo -e "  ${YELLOW}没有活跃会话${NC}"
        return
    fi
    echo -e "${CYAN}=== 向 $count 个会话逐一发送 /clear ===${NC}"
    IFS=$'\n' sorted=($(sort <<<"${ttys[*]}")); unset IFS
    for i in "${!sorted[@]}"; do
        local tab_num=$((i + 1))
        send_clear_tab "$tab_num"
        sleep 0.5
    done
}

send_clear_tmux() {
    local target="$1"
    echo -e "  通过 tmux 向 ${GREEN}$target${NC} 发送 ${YELLOW}/clear${NC} ..."
    tmux send-keys -t "$target" "/clear" Enter
    if [ $? -eq 0 ]; then
        echo -e "  ${GREEN}发送成功${NC}"
    else
        echo -e "  ${RED}发送失败${NC}"
        return 1
    fi
}

# 主逻辑
case "${1:-}" in
    -l|--list)
        echo -e "${CYAN}=== 活跃 Claude Code 会话 ===${NC}"
        list_sessions
        ;;
    -t|--tab)
        if [ -z "${2:-}" ]; then
            echo "用法: cc-clear -t <tab序号>"
            echo "示例: cc-clear -t 1"
            exit 1
        fi
        send_clear_tab "$2"
        ;;
    -a|--all)
        send_clear_all
        ;;
    -p|--pid)
        if [ -z "${2:-}" ]; then
            echo "用法: cc-clear -p <PID>"
            exit 1
        fi
        send_clear_pid "$2"
        ;;
    -c|--cwd)
        if [ -z "${2:-}" ]; then
            echo "用法: cc-clear -c <工作目录>"
            exit 1
        fi
        send_clear_cwd "$2"
        ;;
    --tmux)
        if [ -z "${2:-}" ]; then
            echo "用法: cc-clear --tmux <target>"
            echo "示例: cc-clear --tmux dev:0.1"
            exit 1
        fi
        send_clear_tmux "$2"
        ;;
    --tmux-all)
        echo -e "${CYAN}=== 通过 tmux 向所有 pane 发送 /clear ===${NC}"
        for pane in $(tmux list-panes -a -F '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null); do
            pane_pid=$(tmux display-message -t "$pane" -p '#{pane_pid}' 2>/dev/null)
            if ps -p "$pane_pid" > /dev/null 2>&1; then
                cmd=$(ps -o command= -p "$pane_pid" 2>/dev/null)
                if [[ "$cmd" == *"claude"* ]]; then
                    send_clear_tmux "$pane"
                fi
            fi
        done
        ;;
    -h|--help|"")
        echo "cc-clear — 向 Claude Code 会话发送 /clear"
        echo ""
        echo "用法:"
        echo "  cc-clear -l             列出所有活跃会话"
        echo "  cc-clear -t <N>         向第 N 个 Warp tab 发送 /clear"
        echo "  cc-clear -a             向所有 Warp tab 逐一发送 /clear"
        echo "  cc-clear -p <PID>       向指定 PID 发送 (自动定位 tab)"
        echo "  cc-clear -c <CWD>       向匹配工作目录的会话发送"
        echo ""
        echo "tmux 模式:"
        echo "  cc-clear --tmux <t>     向指定 tmux pane 发送 /clear"
        echo "  cc-clear --tmux-all     向所有运行 claude 的 pane 发送"
        echo ""
        echo "说明:"
        echo "  -t 模式通过 Cmd+数字 切换 Warp tab 后发送"
        echo "  -p/-c 模式自动根据 TTY 推算 tab 序号"
        echo "  tab 推算基于 TTY 排序，可能与实际 tab 顺序不一致"
        ;;
    *)
        echo "未知选项: $1"
        echo "运行 cc-clear --help 查看帮助"
        exit 1
        ;;
esac
